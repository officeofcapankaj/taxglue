# ============================================
# TaxGlue Environment Variables
# ============================================

# ============================================
# Supabase Configuration
# ============================================
# Your Supabase project URL
SUPABASE_URL=https://jgjeuybgideeqcjxvlmn.supabase.co

# Your Supabase anonymous (anon) key
SUPABASE_ANON_KEY=your-anon-key-here

# Your Supabase service role key (for admin operations)
SUPABASE_SERVICE_KEY=your-service-key-here

# Vite-compatible environment variables (for frontend)
VITE_SUPABASE_URL=https://jgjeuybgideeqcjxvlmn.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# Application Settings
# ============================================
# Flask environment (development or production)
FLASK_ENV=development

# Secret key for session management (generate a random string)
FLASK_SECRET_KEY=your-random-secret-key-here